{
  "name": "airflow-ec2-cdk",
  "version": "0.1.0",
  "description": "Deploy Airflow 3.x on EC2 with CDK",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy": "npx cdk deploy --all --require-approval never",
    "deploy:ecs": "npx cdk deploy --all -c executor=ecs --require-approval never",
    "deploy:ec2": "npx cdk deploy AirflowEc2 --require-approval never",
    "destroy": "npx cdk destroy --all --force",
    "destroy:ec2": "npx cdk destroy AirflowEc2 --force"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "aws-cdk": "2.x",
    "ts-node": "^10.9.0",
    "typescript": "5.x"
  },
  "dependencies": {
    "aws-cdk-lib": "2.x",
    "constructs": "^10.0.0"
  }
}
